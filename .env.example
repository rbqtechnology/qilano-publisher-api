PORT=3000
JWT_SECRET=replace_with_secure_random_secret
QILANO_API_TOKEN=replace_with_dashboard_api_token
DEBUG_QUEUE_AUTH=false
PGHOST=your-postgres-host
PGPORT=5432
PGDATABASE=your-postgres-database
PGUSER=your-postgres-user
PGPASSWORD=your-postgres-password
PGSSLMODE=require
WORKER_TOKEN=replace_with_worker_token

# Meta Graph / Instagram publishing
META_GRAPH_VERSION=v22.0
META_GRAPH_TIMEOUT_MS=15000
# Public base used to normalize relative Instagram media paths.
# Example:
# PUBLIC_BASE_URL=https://api.qilano.com
# PUBLIC_MEDIA_PATH_PREFIX=/media
# PUBLIC_MEDIA_BASE_URL=https://cdn.qilano.com/generated
# MEDIA_STORAGE_DIR=/home/ubuntu/publisher-api/media
PUBLIC_BASE_URL=
PUBLIC_MEDIA_PATH_PREFIX=/media
PUBLIC_MEDIA_BASE_URL=
# Instagram publish credentials now come from the selected social_accounts row:
# access_token, instagram_business_account_id, instagram_user_id
X_API_BASE_URL=https://api.x.com

# Internal repost feature flags
# Recommended workflow-primary shadow-mode defaults:
# workflow / n8n remains production-primary
# internal repost stays available for monitoring and manual diagnostics
USE_INTERNAL_CLAIM=true
USE_INTERNAL_STATUS_UPDATES=true
USE_INTERNAL_PREPARE_REPOST=true
USE_INTERNAL_PUBLISH_PAYLOAD=true
USE_INTERNAL_PUBLISH=true
USE_INTERNAL_PUBLISH_MARK_STATUS=true
USE_INTERNAL_REWRITE=true
USE_INTERNAL_REWRITE_FOR_PUBLISH=true
INTERNAL_REPOST_MODE=shadow
USE_INTERNAL_SCHEDULER=false
USE_INTERNAL_FULL_REPOST_FLOW=false

INTERNAL_SCHEDULER_INTERVAL_MS=60000
INTERNAL_SCHEDULER_MAX_RUNS_PER_TICK=1
INTERNAL_SCHEDULER_CONCURRENCY=1
INTERNAL_SCHEDULER_DRY_RUN=false
INTERNAL_SCHEDULER_WORKER_ID=internal-repost-scheduler

# OpenRouter rewrite
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=30000
